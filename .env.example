# Globonexo Sales AI — Backend Environment Variables

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Auth
JWT_SECRET=generate-a-strong-random-string
COOKIE_SECRET=generate-another-strong-random-string
# COOKIE_DOMAIN=.globonexo.com  # optional, set in production to share cookies across api./app. subdomains

# Google OAuth (for Gmail integration)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4-mini

# Retell AI
RETELL_API_KEY=your-retell-api-key
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret

# Apollo.io
APOLLO_API_KEY=your-apollo-master-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@globonexo.com

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# PostHog
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com

# Sentry
SENTRY_DSN=https://...
